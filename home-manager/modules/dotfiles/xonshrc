# ----------------------------
# Completion System & Enhancements
# ----------------------------
# Custom completers for user-defined functions
def wallpaper_completer(prefix, line, begidx, endidx, ctx):
    """Completer for wp (wallpaper) command"""
    import os
    wallpaper_dir = os.path.expandvars("$HOME/Pictures/wallpapers")

    # Get all wallpaper files
    if os.path.exists(wallpaper_dir):
        try:
            files = [f for f in os.listdir(wallpaper_dir) if f != 'wallpaper']
            return set(files)
        except OSError:
            pass

    # Also suggest subcommands
    return {'ls', 'search'}

def display_completer(prefix, line, begidx, endidx, ctx):
    """Completer for d (display) command"""
    try:
        import subprocess
        result = subprocess.run(['autorandr', '--list'], capture_output=True, text=True, check=False)
        if result.returncode == 0:
            profiles = result.stdout.strip().split('\n')
            return set(p.strip() for p in profiles if p.strip())
    except Exception:
        pass
    return set()

def venv_completer(prefix, line, begidx, endidx, ctx):
    """Completer for vac (venv activate) command"""
    try:
        import subprocess
        result = subprocess.run(['uvox', 'list'], capture_output=True, text=True, check=False)
        if result.returncode == 0:
            venvs = result.stdout.strip().split('\n')
            return set(v.strip() for v in venvs if v.strip() and not v.startswith('='))
    except Exception:
        pass
    return set()

# Register custom completers
try:
    from xonsh.completer import add_one_completer
    add_one_completer('wp', wallpaper_completer, 'start')
    add_one_completer('d', display_completer, 'start')
    add_one_completer('vac', venv_completer, 'start')
except ImportError:
    # Fallback for newer xonsh versions with different completer API
    try:
        import xonsh.completer.bash_completer as bash_completer
        bash_completer.COMPLETERS['wp'] = wallpaper_completer
        bash_completer.COMPLETERS['d'] = display_completer
        bash_completer.COMPLETERS['vac'] = venv_completer
    except (ImportError, AttributeError):
        # If completer registration fails, continue without custom completers
        pass

