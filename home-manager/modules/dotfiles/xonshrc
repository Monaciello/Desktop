import os
import os.path
import socket
import subprocess

# ----------------------------
# Constants
# ----------------------------
WALLPAPER_DIR = os.path.expandvars("$HOME/Pictures/wallpapers")
$XONSH_SHOW_TRACEBACK = True

# ----------------------------
# Tools
# ----------------------------
def pwd():
    return os.getcwd()

# ----------------------------
# System Utilities
# ----------------------------
def env_name_cust(pre_chars='[', post_chars='] ■ '):
    env_path = __xonsh__.env.get('VIRTUAL_ENV', '')
    env_name = os.path.basename(env_path)
    if env_name and env_name != 'xonsh':
        return '{WHITE}'+pre_chars+'{YELLOW}'+env_name+'{WHITE}'+post_chars

def nix_shell_name():
    nix_env_name = os.environ.get('name', '')
    if nix_env_name.startswith('fhs'):
        nix_env_name = 'fhs'
    if os.environ.get('IN_NIX_SHELL') and nix_env_name:
        return nix_env_name
    elif os.environ.get('IN_NIX_SHELL'):
        return 'nix'
    return ''

# ----------------------------
# Wallpaper and Display
# ----------------------------

# set_wallpaper: Safely set wallpaper with path validation
# Uses subprocess instead of os.system() to prevent command injection
def set_wallpaper(args):
    """Safely set wallpaper with path traversal protection"""
    if not args:
        print("Usage: set_wallpaper <option> or <wallpaper_name>")
        return None

    option = args[0]
    if option == "ls":
        try:
            subprocess.run(['eza', '--icons', WALLPAPER_DIR], check=True)
        except subprocess.CalledProcessError:
            print("Failed to list wallpapers")
        return None

    wallpaper = option
    wallpaper_path = None

    # Search for wallpaper in directory
    for root, dirs, files in os.walk(WALLPAPER_DIR):
        for file in files:
            name, ext = os.path.splitext(file)
            if name == wallpaper or file == wallpaper:
                full_path = os.path.join(root, file)

                # Security: Prevent path traversal attacks
                try:
                    if not os.path.abspath(full_path).startswith(os.path.abspath(WALLPAPER_DIR)):
                        print("Error: Path traversal detected")
                        return None
                except (ValueError, OSError):
                    print("Error: Invalid path")
                    return None

                wallpaper_path = full_path
                break
        if wallpaper_path:
            break

    if not wallpaper_path:
        print(f"Error: Wallpaper '{wallpaper}' not found in {WALLPAPER_DIR}")
        return None

    # Copy wallpaper using subprocess (safer than os.system)
    try:
        dest = os.path.join(WALLPAPER_DIR, 'wallpaper')
        subprocess.run(['cp', wallpaper_path, dest], check=True)
        subprocess.run(['i3', 'restart'], check=True)
        print(f"✓ Wallpaper changed to {wallpaper}")
    except subprocess.CalledProcessError as e:
        print(f"✗ Error: {e}")
        return None

    return None

# untar: Safely extract tar archives with validation
def untar(args):
    """Safely extract tar archives with filename validation"""
    if not args:
        print("Usage: untar <file.tar.xz|tar.gz|tar.bz2|tar>")
        return None

    filename = args[0]

    # Validate file extension
    if not filename.endswith(('.tar.xz', '.tar.gz', '.tar.bz2', '.tar')):
        print("Error: Not a valid tar archive (use .tar, .tar.gz, .tar.bz2, or .tar.xz)")
        return None

    # Validate file exists
    if not os.path.exists(filename):
        print(f"Error: File not found: {filename}")
        return None

    # Extract safely using subprocess
    try:
        subprocess.run(['tar', '-xf', filename], check=True)
        print(f"✓ Extracted {filename}")
    except subprocess.CalledProcessError as e:
        print(f"✗ Error extracting {filename}: {e}")
        return None

    return None

# set_display: Safely change display configuration with input validation
# Uses subprocess instead of os.system() and validates profile names
import re

def set_display(args):
    """Safely change display configuration with input validation"""
    if not args:
        print("Usage: set_display <profile>")
        return None

    profile = args[0]

    # Validate profile name (alphanumeric, hyphens, underscores only)
    if not re.match(r'^[a-zA-Z0-9_-]+$', profile):
        print(f"Error: Invalid profile name '{profile}' - use alphanumeric, hyphens, underscores only")
        return None

    try:
        subprocess.run(['autorandr', '-l', profile], check=True)
        subprocess.run(['i3', 'restart'], check=True)
        print(f"✓ Display profile changed to {profile}")
    except subprocess.CalledProcessError as e:
        print(f"✗ Error: {e}")
        return None

    return None

# ----------------------------
# Networking
# ----------------------------
def get_local_ip():
    try:
        temp_socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        temp_socket.connect(("8.8.8.8", 80))
        get_local_ip = temp_socket.getsockname()[0]
        temp_socket.close()
        return get_local_ip
    except socket.error:
        return "Unable to retrieve local IP address"

