# git_sync / gup: Safe git workflow with confirmation steps
# ⚠️  WARNING: Automatically stages ALL changes in current directory (git add .)
# Usage: gup <branch> <message>
# Example: gup main "fix typo"
# Safety: Includes confirmation prompts before staging, committing, and pushing
# Best practice: Review 'git status' and 'git diff' before confirming
# For sensitive/production repos: Use individual git commands instead
def git_sync(args):
    """Safe git sync with confirmation prompts (Option B implementation)"""
    if len(args) < 2:
        print("Usage: gup <branch> <message>")
        return

    branch = args[0]
    commit_message = args[1]

    try:
        # Fetch updates
        subprocess.run(['git', 'fetch'], check=True)

        # Pull from origin
        subprocess.run(['git', 'pull', 'origin', branch], check=True)

        # Show current status
        print("\n--- Git Status ---")
        subprocess.run(['git', 'status', '--short'], check=False)

        # Ask for confirmation before staging
        response = input("\nStage all changes? (y/N): ")
        if response.lower() != 'y':
            print("Cancelled")
            return

        # Stage changes
        subprocess.run(['git', 'add', '.'], check=True)

        # Show diff before commit
        print("\n--- Staged Changes ---")
        subprocess.run(['git', 'diff', '--staged'], check=False)

        # Ask for confirmation before commit
        response = input(f"\nCommit with message: '{commit_message}'? (y/N): ")
        if response.lower() != 'y':
            print("Cancelled - resetting staging")
            subprocess.run(['git', 'reset'], check=False)
            return

        # Commit
        subprocess.run(['git', 'commit', '-m', commit_message], check=True)

        # Push with error checking
        result = subprocess.run(['git', 'push', '-u', 'origin', branch], check=False)
        if result.returncode == 0:
            print("✓ Push successful")
        else:
            print("✗ Push failed - commit is local")
            return

    except subprocess.CalledProcessError as e:
        print(f"✗ Git command failed: {e}")
        return
    except Exception as e:
        print(f"✗ Error: {e}")
        return

