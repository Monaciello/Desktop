## 🧩 Module Structure

```nix
{ lib, config, pkgs, ... }:
let cfg = config.mySpace.myModule;
in {
  options.mySpace.myModule = {
    enable = lib.mkEnableOption "...";
    package = lib.mkOption {
      type = lib.types.package; default = pkgs.example; description = "...";
    };
    settings = lib.mkOption {
      type = lib.types.attrsOf lib.types.str; default = {}; description = "...";
    };
  };
  config = lib.mkIf cfg.enable {
    environment.systemPackages = [ cfg.package ];
    assertions = [{ assertion = cfg.settings != {}; message = "Settings can't be empty"; }];
  };
}
```

